# 本地环境与敏感配置
API/.env
.env
.env.*
!.env.example
!API/.env.example

# 本地 Python/conda/venv 环境
python/
.venv/
venv/
env/
__pycache__/
*.py[cod]

# 测试缓存与产物（治理期由 tools/cleanup_test_artifacts.py 一并清理）
.pytest_cache/
.coverage
.coverage.*
htmlcov/

# 顶层散落的临时字母目录（curl / adhoc 脚本残留）
/X/
/Y/
/Z/

# 文件对象治理期 JSON 索引（FILE_SHADOW_WRITE=true 生产运行时生成，不入库）
# 归属：文件 PR-2（[[70 开发过程跟踪/开发编年史/2026-07-18 文件 PR-2 补验收 F-1]]）
data/file_index.json
data/file_index.json.lock
data/file_index.json.*.tmp

# 数据模型治理 PR-4 shadow 双读差异日志（SHADOW_READ_*=true 运行时生成，不入库）
# 归属：数据 PR-4（[[70 开发过程跟踪/PR 状态总账/PR - 数据模型#数据 PR-4]]）
# 目录结构 `data/shadow_diff/<domain>/<yyyymmdd>.jsonl`；保留 .gitkeep 骨架
# 但排除所有实际 diff 输出与运行时生成的 domain 子目录。
data/shadow_diff/**/*.jsonl
data/shadow_diff/*/

# 编辑器与系统临时文件
.idea/
.vscode/
.DS_Store
Thumbs.db
