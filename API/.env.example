# Infinite Canvas 环境变量示例
# 使用方法：
# 1. 复制本文件为 API/.env
# 2. 只填写你实际使用的平台密钥和地址
# 3. API/.env 已加入 .gitignore，不会提交到远程仓库


# 公网部署地址。部署到云服务器并绑定域名时填写。
PUBLIC_BASE_URL=
PUBLIC_MEDIA_BASE_URL=
PUBLIC_MEDIA_TOKEN=


# ComfyUI 后端地址，多个地址用英文逗号分隔。
COMFYUI_INSTANCES=127.0.0.1:8188


# 通用/推荐 API 平台。
# 例如使用 APIMart 时，可以把 COMFLY_BASE_URL 改成 https://api.apimart.ai
COMFLY_BASE_URL=https://ai.comfly.chat
COMFLY_API_KEY=


# 默认模型列表，多个模型用英文逗号分隔。
CHAT_MODEL=gpt-4o-mini
IMAGE_MODEL=gpt-image-2
CHAT_MODELS=gpt-4o-mini,gemini-3.1-flash-image-preview-2k
IMAGE_MODELS=gpt-image-2,nano-banana-pro
VIDEO_MODELS=veo3-fast
SYSTEM_PROMPT=You are a helpful assistant.


# ModelScope
MODELSCOPE_API_KEY=
MODELSCOPE_CHAT_MODELS=


# RunningHub
RUNNINGHUB_API_KEY=
RUNNINGHUB_WALLET_API_KEY=


# 火山引擎 / 方舟
ARK_API_KEY=
VOLCENGINE_ACCESS_KEY_ID=
VOLCENGINE_SECRET_ACCESS_KEY=


# CLI 集成，可留空让项目自动查找。
CODEX_BIN=
GPT_IMAGE_2_SKILL_BIN=
GPT_IMAGE_2_SKILL_AUTH_FILE=
CODEX_AUTH_FILE=
GPT_IMAGE_2_SKILL_API_KEY=
OPENAI_API_KEY=
CODEX_CLI_TIMEOUT=900

ANTIGRAVITY_BIN=
AGY_BIN=
GEMINI_BIN=
GEMINI_CLI_TIMEOUT=900
ANTIGRAVITY_IMAGE_TIMEOUT=300
GEMINI_CLI_IMAGE_TIMEOUT=300

JIMENG_BIN=
JIMENG_USE_WSL=
JIMENG_WSL_DISTRO=
JIMENG_POLL_SECONDS=900


# 超时和限制，单位通常为秒。
REQUEST_TIMEOUT=1800
IMAGE_TASK_TIMEOUT=1800
IMAGE_POLL_INTERVAL=2
APIMART_IMAGE_TASK_TIMEOUT=1800
APIMART_IMAGE_POLL_INTERVAL=5
APIMART_IMAGE_INITIAL_POLL_DELAY=10
VIDEO_POLL_TIMEOUT=1800
COMFYUI_HISTORY_TIMEOUT=1800
COMFYUI_DOWNLOAD_TIMEOUT=120
ONLINE_IMAGE_PROMPT_MAX_LENGTH=20000
VIDEO_PROMPT_MAX_LENGTH=4000
LLM_MESSAGE_MAX_LENGTH=20000
MAX_HISTORY_MESSAGES=30
CHAT_ATTACHMENT_MAX=20
ONLINE_IMAGE_REFERENCE_MAX=20
LOCAL_IMAGE_IMPORT_MAX_BYTES=52428800


# 视频/音频临时上传辅助。
CLOUD_VIDEO_UPLOAD_SERVICE=auto
APIMART_TRY_VIDEO_UPLOAD=false
TEMP_SH_MAX_BYTES=4294967296
TEMP_SH_UPLOAD_URL=https://temp.sh/upload
LITTERBOX_UPLOAD_URL=https://litterbox.catbox.moe/resources/internals/api.php
LITTERBOX_TIME=72h
